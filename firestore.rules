rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User validation
    function isValidUser(data) {
      return data.keys().hasAll(['fullName', 'email', 'birthDate']) 
        && data.keys().size() <= 6
        && data.fullName is string && data.fullName.size() >= 2 && data.fullName.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.birthDate is string && data.birthDate.size() <= 20
        && (!data.keys().hasAny(['profilePic']) || (data.profilePic is string && data.profilePic.size() <= 500));
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data);
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(request.resource.data);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    match /config/app {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.token.email == "ayuuktv42@gmail.com"; 
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
