{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "Full name of the user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Primary email address"
        },
        "birthDate": {
          "type": "string",
          "description": "User's birth date"
        },
        "profilePic": {
          "type": "string",
          "description": "URL to user's profile picture"
        }
      },
      "required": ["fullName", "email", "birthDate"]
    },
    "Post": {
      "title": "Post",
      "description": "Uploaded media post",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "url", "type", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Chat room between users",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "updatedAt"]
    },
    "AppConfig": {
      "title": "AppConfig",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "appName": { "type": "string" },
        "adminEmails": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["appName"]
    },
    "Call": {
      "title": "Call",
      "description": "1v1 Video call session",
      "type": "object",
      "properties": {
        "callerId": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "ended"] },
        "offer": { "type": "object" },
        "answer": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["callerId", "receiverId", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "posts/{postId}": {
      "schema": "Post",
      "description": "Collection of media posts"
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "Collection of chat rooms"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    },
    "calls/{callId}": {
      "schema": "Call",
      "description": "Video call signaling"
    },
    "calls/{callId}/callerCandidates/{id}": {
      "schema": "object",
      "description": "ICE Candidates from caller"
    },
    "calls/{callId}/receiverCandidates/{id}": {
      "schema": "object",
      "description": "ICE Candidates from receiver"
    },
    "config/app": {
      "schema": "AppConfig",
      "description": "Global settings"
    }
  }
}
